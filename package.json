{
  "name": "blossom-word-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Blossom Word Game - a free daily word hunt puzzle game inspired by Spelling Bee.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "cf:dev": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "date-fns": "^4.4.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.100.0"
  }
}
